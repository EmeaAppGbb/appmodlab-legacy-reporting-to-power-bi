<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="urn:crystal-reports:schemas:report-detail">
  <ReportName>Surgical Outcomes Report</ReportName>
  <DataSource>OracleConnection</DataSource>
  <Query>
    SELECT s.surgery_id, s.surgery_date, s.procedure_code, s.surgeon_name,
           s.duration_minutes, s.outcome_code, c.complication_description
    FROM surgeries s
    LEFT JOIN complications c ON s.surgery_id = c.surgery_id
    WHERE s.surgery_date BETWEEN :StartDate AND :EndDate
  </Query>
  <Parameters>
    <Parameter Name="StartDate" Type="Date" Prompt="Start Date"/>
    <Parameter Name="EndDate" Type="Date" Prompt="End Date"/>
  </Parameters>
  <Formulas>
    <Formula Name="ComplicationRate">
      <Expression>
        Count({complications.complication_id}) / Count({surgeries.surgery_id}) * 100
      </Expression>
    </Formula>
  </Formulas>
  <SubReports>
    <SubReport Name="ComplicationDetails" LinkField="surgery_id"/>
  </SubReports>
</Report>
